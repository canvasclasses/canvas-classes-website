# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies — apply anywhere in the monorepo
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage

# next.js — applies to any app under apps/
.next/
.next-*/
out/

# production
build

# misc
.DS_Store
*.pem

# NCERT corpus source PDFs/text — bulk binaries kept local, not committed.
# Distilled _agents/ncert/**/*.md indexes ARE committed. Re-fetch sources per
# the curl command in each chapter file's header (see _agents/ncert/NCERT_INDEX.md).
_agents/ncert/_source/

# Claude Code — local-only files (conversation history, local settings, commands)
.claude/worktrees/
.claude/projects/
.claude/commands/
.claude/settings.local.json
.claude/settings.json
.claude/scheduled_tasks.lock

# Superpowers — local brainstorm scratch / runtime state
.superpowers/

# Backup / temp files
*.bak
*.bak.*

# Generated script output — keep the scripts in git, never their output artifacts
scripts/output/
scripts/image_candidates.md

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — only templates are committed; real values stay local
.env*
!.env.example
!apps/*/.env.development.local.example
!apps/*/.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Reference material — local only, not part of the codebase
class 11 & 12/

# Source PDFs for book building — large files, local only
_source_pdfs/

# one-time batch insertion scripts (atom/book/crucible data pipelines)
/scripts/insert_*_b*.js
/scripts/insert_book_*.js
/scripts/atom_*.js
/scripts/fix_*.js
/scripts/add_*.js
/scripts/swap_*.js
/scripts/update_*.js
/scripts/register_*.json
/scripts/book_ch*.json
/scripts/audit_*_final.js
/scripts/check_aldehyde_carboxylic_questions.js
/scripts/update_carbonyl_chapter_ids.js
/scripts/final_merge_verification.js

# one-time book-build scratch — diagnostics, dumps, backups (keep toolkit .js, drop scratch data)
/scripts/_diag_*.js
/scripts/_bias_detail.mjs
/scripts/_validate_ch.mjs
/scripts/_ext_*.json
/scripts/_kaveri_full.json
/scripts/_kaveri_summary.txt
/scripts/_kaveri_backups/
# per-batch intermediate data inside book-fix toolchains (regenerable; mirrors scripts/math-solutions convention)
/scripts/kaveri-fix/_*.json
/scripts/kaveri-fix/_ch1_devanagari_trial.js
/scripts/kaveri-fix/_verify_phase1.ts
/scripts/kaveri-fix/_verify_recommender.ts
/scripts/hindi-fix/_*.json
/scripts/science-quiz/_*.json
/scripts/science-practice/_*.json
# one-time solution/livebook batch scratch — spent insert/fix/audit scripts + DB
# rollback snapshots (already applied or regenerable; backups kept LOCAL as undo
# nets, never committed). Reusable toolkits (scripts/lib, svg-mapper, ncert,
# normalize-ce-charges.js) are intentionally NOT matched here.
/scripts/_batch_*.js
/scripts/_phase1_buffer_*.js
/scripts/_fix_*.js
/scripts/_mole_audit_*
/scripts/_backup_*.json
/scripts/*_rollback_backup.json
/scripts/inspect_*.js
/scripts/save_solutions_rev2.js

# automation pipeline output
/automation/output/
/automation/logs/
/automation/progress.db
/automation/node_modules/

# root-level one-time scripts and temp files
query_db.js
html_output.txt
*.html

# Simulator/public HTML files must be deployed — un-ignore them under each app
!apps/student/public/**/*.html
!apps/student/public/*.html
!apps/admin/public/**/*.html
!apps/admin/public/*.html

# automation one-time scripts (insert/fix/check/audit)
/automation/insert_*.js
/automation/fix_*.js
/automation/check_*.js
/automation/audit_*.js
/automation/bio_b*.js
/automation/biomolecules_batch*.js
/automation/amines_batch*.js
.next-preview

# Sentry Config File
.env.sentry-build-plugin

# one-time throwaway: all underscore-prefixed scratch scripts/dumps, root scratch files, logs
/scripts/_*
/scratch_*
*.log

# NCERT source PDFs — large binary source material (Class 11/12 Biology book
# builds). Not app code, never deployed (Vercel ships only .next + public/).
# The extracted per-chapter _ncert_source.txt files stay tracked; only the raw
# PDFs are ignored. Untracked 2026-07-19; local copies retained on disk.
**/_ncert_pdfs/*.pdf
