# =============================================================================
# apps/student/.env.development.local — STUDENT-only env vars
# =============================================================================
# Loaded by `next dev` in apps/student/. Overrides anything in the shared
# apps/student/.env.local (which is a symlink to root .env.local).
#
# Add ONLY vars that the student app needs and the admin app does NOT.
# Anything used by both apps belongs in root .env.local instead.
# =============================================================================

# --- Feature flags ---
NEXT_PUBLIC_FEATURE_ADAPTIVE_PRACTICE=true

# --- Google OAuth (student sign-in) ---
# GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# --- Analytics ---
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_CLARITY_ID=your_clarity_id
# NEXT_PUBLIC_CF_BEACON_TOKEN=your_cloudflare_beacon_token

# --- SEO ---
# GOOGLE_SITE_VERIFICATION=your_google_site_verification_token

# --- Cron job secret (used by Vercel cron endpoints) ---
# CRON_SECRET=long_random_string_used_by_vercel_cron_invocations

# --- BITSAT candidate-scores third-party API (server-only) ---
# Powers the Score Analytics tab on /bitsat. The server calls the MeritVerse
# BITSAT scorecard API (GET /api/export), aggregates the raw `final_score`
# values, and returns ONLY aggregates to the browser. The key is sent as the
# `X-API-Key` header and NEVER reaches the client (route + adapter are
# server-only). Leave the key unset → the analytics tab shows an empty state.
#
# Required: the X-API-Key secret (get it from the platform admin; do NOT commit it):
# BITSAT_SCORES_API_KEY=your_x_api_key
#
# Optional overrides (sensible defaults bake in the production endpoint):
#   URL defaults to the production worker; override only for a local worker:
# BITSAT_SCORES_API_URL=http://localhost:8787/api/export
#   Host pin (default "workers.dev"); change only if the vendor moves domains:
# BITSAT_SCORES_API_ALLOWED_HOST=workers.dev
