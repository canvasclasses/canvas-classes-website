# =============================================================================
# apps/admin/.env.development.local — ADMIN-only env vars
# =============================================================================
# Loaded by `next dev` in apps/admin/. Overrides anything in the shared
# apps/admin/.env.local (which is a symlink to root .env.local).
#
# Add ONLY vars that the admin app needs and the student app does NOT.
# Anything used by both apps belongs in root .env.local instead.
# =============================================================================

# --- Sentry (admin-app error tracking) ---
# NEXT_PUBLIC_SENTRY_DSN_ADMIN=https://your-public-admin-dsn@sentry.io/PROJECT_ID
# SENTRY_DSN_ADMIN=https://your-server-admin-dsn@sentry.io/PROJECT_ID
