# =============================================================================
# ROOT .env.local — SHARED env vars (used by BOTH admin + student apps + scripts)
# =============================================================================
# Symlinked into each app as apps/<app>/.env.local. Also loaded directly by
# /scripts/*.js via `dotenv.config({ path: '.env.local' })`.
#
# Layout (see CLAUDE.md §10 ENV FILE LAYOUT for full details):
#   .env.local                                  ← THIS template (shared)
#   apps/admin/.env.local                       ← symlink to root .env.local
#   apps/admin/.env.development.local           ← admin-only overrides (Sentry DSN admin)
#   apps/student/.env.local                     ← symlink to root .env.local
#   apps/student/.env.development.local         ← student-only (Google OAuth, GA, etc.)
#
# Next.js loads `.env.development.local` BEFORE `.env.local` in dev mode, so
# app-specific values automatically override shared ones.
# =============================================================================

# --- MongoDB Atlas (Crucible's question bank, user progress, etc.) ---
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/crucible

# --- Cloudflare R2 (asset uploads — questions, books, blog images) ---
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=canvas-chemistry-assets
R2_PUBLIC_URL=https://canvas-chemistry-assets.YOUR_ACCOUNT.r2.dev

# --- Supabase (authentication) ---
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key   # only if shared packages need it

# --- Admin access control ---
ADMIN_EMAILS=admin1@example.com,admin2@example.com
ADMIN_SECRET=long_random_string_for_script_authentication
# NOTE: do NOT create a NEXT_PUBLIC_ADMIN_SECRET — NEXT_PUBLIC_* vars are inlined into the
# browser bundle, and the admin secret is a full auth-bypass header. It must stay server-only.

# --- On-demand ISR revalidation (student /api/revalidate; called by admin app + scripts) ---
# Shared because: student app VERIFIES it, admin app + /scripts SEND it (x-revalidate-secret).
# Must also be set in BOTH Vercel projects. Server-only — never NEXT_PUBLIC_*.
REVALIDATE_SECRET=long_random_string_for_revalidation_calls
# Where the bridge posts to. Set on the ADMIN app only (Vercel admin project +
# apps/admin/.env.local) — the student app must NOT set it (its own
# revalidatePath() already covers same-deployment freshness). Scripts default
# to the production URL when unset.
# REVALIDATE_URL=https://www.canvasclasses.in/api/revalidate

# --- AI features (used by shared services) ---
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- Public base URL (shared by both apps for canonical links / OG tags) ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# =============================================================================
# Template files for the per-app overrides:
#   apps/admin/.env.development.local.example
#   apps/student/.env.development.local.example
# =============================================================================
